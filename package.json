{
	"name": "chess-connect",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"prod": "AI_RUNTIME_BACKEND=cpu PORT=4400 node build/",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"ai:self-play": "tsx scripts/ai/self-play.ts",
		"ai:train": "tsx scripts/ai/train.ts",
		"ai:auto-train": "tsx scripts/ai/auto-train.ts",
		"ai:reanalyse-games": "tsx scripts/ai/reanalyse-games.ts",
		"ai:train-network": "tsx scripts/ai/train-network.ts",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"prisma:generate": "prisma generate",
		"prisma:migrate:dev": "prisma migrate dev",
		"prisma:migrate:deploy": "prisma migrate deploy",
		"prisma:studio": "prisma studio"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-node": "^5.5.2",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@tensorflow/tfjs-node": "^4.22.0",
		"@types/node": "^24",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"prisma": "^7.5.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"svelte-confetti": "^2.3.2",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@lucide/svelte": "^0.577.0",
		"@prisma/adapter-better-sqlite3": "^7.5.0",
		"@prisma/client": "^7.5.0",
		"@tensorflow/tfjs": "^4.22.0",
		"better-sqlite3": "^12.8.0",
		"dotenv": "^17.3.1",
		"svelte-i18n": "^4.0.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@prisma/client",
			"@prisma/engines",
			"better-sqlite3",
			"@tensorflow/tfjs-node",
			"prisma"
		]
	}
}
